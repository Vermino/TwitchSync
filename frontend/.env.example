# Frontend Environment Variables
VITE_API_URL=http://localhost:3001
VITE_TWITCH_CLIENT_ID=your_twitch_client_id_here
VITE_TWITCH_REDIRECT_URI=http://localhost:3001/auth/twitch/callback

# Note: This should match the Client ID from your Twitch app
# To get Twitch credentials:
# 1. Go to https://dev.twitch.tv/console/apps
# 2. Click "Create App" or select existing app
# 3. Copy the Client ID (same as backend)
# 4. The redirect URI should match the backend configuration