# Frontend Environment Variables
VITE_API_URL=http://localhost:3501
VITE_TWITCH_CLIENT_ID=your_twitch_client_id_here
VITE_TWITCH_REDIRECT_URI=http://localhost:3000/auth/callback
VITE_WS_URL=http://localhost:3501

# Note: VITE_TWITCH_CLIENT_ID is visible in the browser bundle — this is safe for OAuth apps.
# The Twitch Developer Console restricts which redirect URIs are valid.
# Backend redirect URI must point to the backend: http://localhost:3501/auth/twitch/callback
# Frontend redirect URI must point to the frontend: http://localhost:3000/auth/callback