# =============================================================================
# TwitchSync — Environment Variables
# Copy this file to .env and fill in your values before running docker-compose
#
#   cp .env.example .env
#   docker compose up -d --build
# =============================================================================

# ── Twitch API ────────────────────────────────────────────────────────────────
# Get these from https://dev.twitch.tv/console → your application
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# OAuth redirect URL — must EXACTLY match what you registered in the Twitch console.
#
# ✅ Local dev (browser on same machine):
#    TWITCH_REDIRECT_URI=http://localhost:2261/auth/twitch/callback
#
# ✅ Homelab by IP (replace with your server's LAN IP):
#    TWITCH_REDIRECT_URI=http://192.168.1.100:2261/auth/twitch/callback
#
# ✅ With a domain / reverse proxy:
#    TWITCH_REDIRECT_URI=https://twitchsync.yourdomain.com/auth/twitch/callback
#
# NOTE: In the Docker setup, the frontend nginx runs on port 2261 and proxies
# /auth/* to the backend — so the redirect URL uses port 2261.
TWITCH_REDIRECT_URI=http://YOUR_SERVER_IP:2261/auth/twitch/callback

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=twitchsync
DB_USER=twitchsync
DB_PASSWORD=changeme_use_a_strong_password

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS

# ── Storage ───────────────────────────────────────────────────────────────────
# Path INSIDE the container where VODs are saved.
# This is mapped to a host path via the docker-compose volumes section.
# Change the left side of the volume mount (host path), not this value.
STORAGE_PATH=/data/vods

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
