# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twitchsync
DB_USER=twitchsync_user
DB_PASSWORD=twitchsync_password
DB_MAX_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000

# Twitch API Configuration
# To get Twitch credentials:
# 1. Go to https://dev.twitch.tv/console/apps
# 2. Click "Create App" or select existing app
# 3. Set "OAuth Redirect URLs" to: http://localhost:3001/auth/twitch/callback
# 4. Copy the Client ID and generate a Client Secret
# 5. Replace the values below with your actual credentials
# Note: The OAuth authentication will not work until you provide real credentials
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here
TWITCH_REDIRECT_URI=http://localhost:3001/auth/twitch/callback

# Server Configuration
PORT=3501
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Storage Configuration
MEDIA_SERVER_PATH=./storage/media
STORAGE_PATH=./storage
TEMP_PATH=./temp
TEMP_DOWNLOAD_PATH=./temp/downloads

# Download Manager Configuration
TEMP_DIR=./temp
MAX_CONCURRENT_DOWNLOADS=3
DOWNLOAD_RETRY_ATTEMPTS=3
DOWNLOAD_RETRY_DELAY=5000
CLEANUP_INTERVAL=3600

# Development Settings
LOG_LEVEL=debug
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_64_char_hex_string
JWT_EXPIRES_IN=7d

# Download path
DOWNLOAD_PATH=./downloads